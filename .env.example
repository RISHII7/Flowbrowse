NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Neon Postgres (pulled by `neon env pull` into .env.local)
# DATABASE_URL is the pooled connection used at runtime; DATABASE_URL_UNPOOLED
# is the direct connection used for migrations / DDL (drizzle-kit).
DATABASE_URL=
DATABASE_URL_UNPOOLED=
NEON_BRANCH=

# Trigger.dev — get from the dashboard API Keys page (DEV key starts with tr_dev_)
TRIGGER_SECRET_KEY=